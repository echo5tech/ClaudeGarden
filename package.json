{
  "name": "claude-garden",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "web": "turbo run dev --filter=@garden/web",
    "mobile": "turbo run start --filter=@garden/mobile",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:migrate:new": "supabase migration new",
    "db:types": "supabase gen types typescript --local > packages/database/src/types.ts",
    "db:lint": "supabase db lint"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.14",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
