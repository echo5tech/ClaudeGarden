# Copy this file to apps/web/.env.local and apps/mobile/.env.
# For local dev, get values by running `supabase start` and checking the output.
# For production, find values in your Supabase project dashboard.

# Web (Next.js — NEXT_PUBLIC_ prefix is client-readable)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Mobile (Expo — EXPO_PUBLIC_ prefix is client-readable)
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Server-only — never expose to clients. Used by Edge Functions and admin scripts.
SUPABASE_SECRET_KEY=your-supabase-secret-key

# Permapeople catalog credentials (Edge Function secrets in production).
PERMAPEOPLE_KEY_ID=
PERMAPEOPLE_KEY_SECRET=
